# ==============================================================================
# OTP Configuration Template
#
# This project uses CLI arguments for all execution to avoid leaving secrets
# in environment variables. However, if wrapping this tool in automation
# scripts, these are the expected environment variables.
# ==============================================================================

# Default directory for generated keys
OTP_KEY_DIR=./keys

# Default directory for plaintext inputs
OTP_INPUT_DIR=./input_files

# Default directory for ciphertext outputs
OTP_OUTPUT_DIR=./output_files

# Log verbosity (0 = NORMAL, 1 = VERBOSE)
OTP_LOG_LEVEL=0

# Security toggle: Automatically securely delete keys after successful decryption
OTP_AUTO_SELF_DESTRUCT=false
